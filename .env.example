# ─────────────────────────────────────────────
#  TikTok Video Publisher — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── TikTok Developer App ───────────────────────
# Get these from https://developers.tiktok.com/
# Create an app → Products → Login Kit + Content Posting API

TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# ── OAuth Redirect URI ────────────────────────
# Must match EXACTLY what you register in TikTok Developer Portal
# TikTok does NOT accept localhost — use ngrok for local development:
#   1. Run: ngrok http 3000
#   2. Copy the https://xxxx.ngrok-free.app URL
#   3. Set REDIRECT_URI to: https://xxxx.ngrok-free.app/auth/callback
# For production: https://yourdomain.com/auth/callback

REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/callback

# ── Server ────────────────────────────────────
PORT=3000

# ── Session Secret ────────────────────────────
# Any long random string (openssl rand -hex 32)
SESSION_SECRET=change_me_to_something_random
